# ─── Flask ────────────────────────────────────────────
SECRET_KEY=your-very-secret-key-here
FLASK_ENV=production

# ─── Owner Credentials ────────────────────────────────
OWNER_EMAIL=owner@yourdomain.com
OWNER_PASSWORD=your-secure-owner-password

# ─── Discord Bot ──────────────────────────────────────
TOKEN=your-discord-bot-token-here

# ─── Discord OAuth ────────────────────────────────────
DISCORD_CLIENT_ID=your-discord-app-client-id
DISCORD_CLIENT_SECRET=your-discord-app-client-secret
DISCORD_REDIRECT_URI=https://your-render-domain.onrender.com/auth/discord/callback

# ─── Google OAuth ─────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-render-domain.onrender.com/auth/google/callback

# ─── Firebase ─────────────────────────────────────────
FIREBASE_DATABASE_URL=https://web-massaging-589b7-default-rtdb.firebaseio.com
FIREBASE_PROJECT_ID=web-massaging-589b7
FIREBASE_STORAGE_BUCKET=web-massaging-589b7.firebasestorage.app

# ─── Adsterra (Optional) ──────────────────────────────
ADSTERRA_BANNER_ID=
ADSTERRA_NATIVE_ID=
ADSTERRA_SOCIAL_BAR=
ADSTERRA_SMART_LINK=
ADSTERRA_POPUP=
